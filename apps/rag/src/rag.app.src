{application, rag, [
    {description, "Shared root + notation for the hecate-rag service's umbrella apps"},
    {vsn, "0.1.0"},
    {registered, [rag_store]},
    {mod, {rag_app, []}},
    {applications, [
        kernel,
        stdlib,
        crypto,
        cowboy,
        jsx,
        esqlite,
        reckon_db,
        evoq,
        hecate_vector,
        hecate_embed
    ]},
    {env, []},
    {modules, []},
    {licenses, ["Apache-2.0"]}
]}.
