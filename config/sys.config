[
    {hecate_rag, [
        {http_port,   8470},
        {data_dir,    "/var/lib/hecate-rag/data"},
        {index_dir,   "/var/lib/hecate-rag/index"},
        {event_store_id, rag_store}
    ]},

    {hecate_om, [
        {service_cert_path, "/etc/hecate/secrets/service-cert.pem"},
        {station_socket,    "/run/macula/station.sock"},
        {health_port,       8470}
    ]},

    {hecate_embed, [
        {default_model_id, <<"intfloat/multilingual-e5-small">>},
        {default_dim, 384}
    ]}
].
