%% Dev/local sys.config — runs on the laptop, no realm, no station.

[
    {hecate_rag, [
        {http_port,   8470},
        {data_dir,    "/home/rl/.hecate/hecate-rag/data"},
        {index_dir,   "/home/rl/.hecate/hecate-rag/index"},
        {event_store_id, rag_store}
    ]},

    {hecate_om, [
        {service_cert_path, "/home/rl/.hecate/hecate-rag/service-cert.pem"},
        {station_socket,    "/home/rl/.hecate/hecate-rag/station.sock"},
        {health_port,       8470}
    ]},

    {hecate_embed, [
        {backend,          ollama},
        {default_model_id, <<"nomic-embed-text">>},
        {default_dim,      768},
        {ollama_url,       "http://127.0.0.1:11434/api/embeddings"}
    ]}
].
