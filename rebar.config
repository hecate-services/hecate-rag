%% -*- mode: erlang -*-
%% rebar3 configuration for hecate-rag (realm service daemon)

{erl_opts, [debug_info, warnings_as_errors]}.

{deps, [
    %% Service substrate
    {hecate_om, {git, "https://codeberg.org/hecate-services/hecate-om.git", {branch, "main"}}},

    %% Event sourcing
    {reckon_db,    "~> 2.3"},
    {evoq,         "~> 1.15"},
    {reckon_evoq,  "~> 2.1"},
    {reckon_gater, "~> 2.1"},

    %% Local HTTP (admin / health)
    {cowboy, "~> 2.12.0"},

    %% Read model storage
    {esqlite, "~> 0.8.0"},

    %% Local RAG primitives (git deps until hex publish)
    {hecate_vector, {git, "https://codeberg.org/hecate-social/hecate-vector.git", {branch, "main"}}},
    {hecate_embed,  {git, "https://codeberg.org/hecate-social/hecate-embed.git",  {branch, "main"}}},
    {macula_rag,    {git, "https://codeberg.org/macula-io/macula-rag.git",        {branch, "main"}}}
]}.

{relx, [
    {release, {hecate_rag, "0.1.0"}, [
        hecate_rag,

        hecate_om,

        reckon_db,
        evoq,
        reckon_evoq,

        rag,

        embed_corpus,
        refresh_corpus,
        serve_retrieval,

        project_chunks,
        project_sources,

        query_chunks,
        query_sources,

        hecate_vector,
        hecate_embed,
        macula_rag
    ]},
    {dev_mode, true},
    {include_erts, false},
    {extended_start_script, true}
]}.

{shell, [
    {config, "config/sys.config"},
    {apps, [hecate_rag]}
]}.

{profiles, [
    {prod, [
        {relx, [
            {dev_mode, false},
            {include_erts, true}
        ]}
    ]}
]}.
